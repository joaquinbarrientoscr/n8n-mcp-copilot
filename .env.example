# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql://copilot:copilot_dev@localhost:5433/copilot

# ============================================================
# API keys — OpenAI only (embeddings + generation + judge)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# Models
# ============================================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
GENERATION_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# ============================================================
# Ingestion
# ============================================================
N8N_DOCS_BASE_URL=https://docs.n8n.io
N8N_SITEMAP_URL=https://docs.n8n.io/sitemap.xml
MCP_DOCS_BASE_URL=https://modelcontextprotocol.io
MAX_PAGES_PER_SOURCE=150
REQUEST_DELAY_SECONDS=0.5
USER_AGENT=n8n-mcp-copilot/0.1 (educational; contact joaquin@joaquinbarrientoscr.com)

# ============================================================
# Retrieval defaults
# ============================================================
DEFAULT_TOP_K=5
DEFAULT_CHUNKING_STRATEGY=fixed_size
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ============================================================
# Optional: reranking
# ============================================================
# COHERE_API_KEY=...
RERANK_ENABLED=false
RERANK_TOP_N=20

# ============================================================
# UI
# ============================================================
APP_TITLE=n8n + MCP Copilot
